organize_auto() {
  (
    echo "Desktop cleanup"

    mkdir -p "$HOME/Pictures/unsorted/"
    mv -v -i --target-directory "$HOME/Pictures/unsorted/" \
      "$HOME/Desktop"/*.{png,gif,jpg,svg,mp3,mp4}

    mkdir -p "$HOME/Software/Unsorted/"
    mv -v -i --target-directory "$HOME/Software/Unsorted/" \
      "$HOME/Desktop"/*.exe

    ls -d "$HOME/Desktop"/*.lnk >/dev/null 2>&1 && \
      prename "s/(.+)\.... - Shortcut.lnk/\$1.lnk/g" "$HOME/Desktop"/*.lnk

    mkdir -p "$APPDATA/Microsoft/Windows/Start Menu/Programs/Unsorted"
    mv -v -i --target-directory "$APPDATA/Microsoft/Windows/Start Menu/Programs/Unsorted/" \
      "$HOME/Desktop"/*.lnk \
      "$HOME/Desktop"/*.url \
      C:/Users/Public/Desktop/*.lnk

    echo "Downloads to documents, pictures, ..."

    mkdir -p "$HOME/Documents/unsorted/"
    mkdir -p "$HOME/Pictures/unsorted/"
    for downloads in "C:/Downloads" "$HOME/Downloads" "$HOME/Desktop"; do
      mv -v -i --target-directory "$HOME/Documents/unsorted/" \
        "$downloads"/*.txt \
        "$downloads"/*.csv \
        "$downloads"/*.doc* \
        "$downloads"/*.xls* \
        "$downloads"/*.pdf* \
        "$downloads"/*.ppt* \

      mv -v -i --target-directory "$HOME/Pictures/unsorted/" \
        "$downloads"/*-vid1.mp4 \
        "$downloads"/*.png      \
        "$downloads"/*.psd      \
        "$downloads"/*.gif      \
        "$downloads"/*.jpg      \
        "$downloads"/*.svg      \
        "$downloads"/*.webp     \
        "$downloads"/*-img.zip  \
        "$downloads"/*-gif1.mp4

      mv -v -i --target-directory "$HOME/Music/Unsorted/" \
        "$downloads"/*.mp3

      mv -v -i --target-directory "$HOME/Books/Unsorted/" \
        "$downloads"/*.epub

      [[ -d "E:/partial/autoimport/" ]] && \
      mv -v -i --target-directory "E:/partial/autoimport/" \
        "$downloads"/*.torrent

      mv -v -i --target-directory "$HOME/Torrents/" \
        "$downloads"/*.torrent

      mv -v -i --target-directory "$HOME/Software/Unsorted/" \
        "$downloads"/*.exe

      mv -v -i --target-directory "$HOME/Software/Install/" \
        "$downloads"/*.msi
    done

    mv -v --target-directory "$HOME/Projects/FantasyConsole/Pico8/carts/" \
      "$HOME/Downloads"/*.{p8.png,p8} \
      "$HOME/Pictures/Unsorted"/*.{p8.png,p8} \
      "$HOME/Pictures"/*.{p8.png,p8}

  ) #  2>&1 | grep -v "cannot stat" # Breaks interactive flag
}

