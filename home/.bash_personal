  find -iwholename "*$orig* [conflicted*" | while read file; do
    echo "=============="
    echo "$last -> $file"
    diff "$last" "$file"
    last="$file"
  done
}

pip_update() {
  choice_table=$(
    gum spin --title "Loading outdated packages" --show-output -- \
      python3 -m pip list --outdated
  )
  choices=$(
    gum choose --no-limit -- $(\
      echo "$choice_table" | tail -n +3 | cut -d' ' -f 1
  ))
  gum confirm "$choices" && \
    python3 -m pip install -U $choices
}

