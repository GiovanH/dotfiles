## Shell hacks

# Use scripts as extensionless commands
for sc in ~/dotfiles/scripts/*.{py,sh}; do
  [[ ! -f "$sc" ]] && continue
  filename="$(basename -- "$sc")"
  hash -p "$sc" "${filename%.*}"
done

use() {
  if [ -z "$1" ]; then
    echo "use: Pick alternative executable from PATH to set as an alias"
    echo "e.g. use find"
  fi
  alt=$(eval "gum choose --select-if-one -- $(where "$1" | linestostrings)")
  eval "alias '$1'='$(printf "%q" "$alt")'"
  type "$1"
}

