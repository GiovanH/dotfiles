# Squash fixup commits between head and the latest push
alias autosquash='git rebase --interactive --autosquash $(git rev-parse origin/HEAD)'

gm_rm_their_deletions()  { git rm  "$(git status -s | grep -Po '^.D \K(.+)$')"; }
