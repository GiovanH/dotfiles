extract_flatten_all() {
  while read -r z; do
    extracttoself "$z" \
    && flatten_all "$dirname/" \
    && rm -v "$z"
  done < <(find . \( -iname "*.zip" -o -iname "*.gz" \))
}

find_sparse_directories() {
  # List directories with N or fewer files in them
  maxfiles=${1:-'8'}
  find */ -type d -exec sh -c 'set -- "$0"/*.*; [ $# -le '$maxfiles' ]' {} \; -print
}

